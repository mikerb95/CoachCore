# ── Auth.js ──────────────────────────────────────────────────────────────
# Genera uno nuevo con:  openssl rand -base64 33
AUTH_SECRET="cámbiame-por-un-secreto-aleatorio"
# En producción Auth.js detecta la URL automáticamente en Vercel.
# Para dev local puedes dejarlo así:
AUTH_URL="http://localhost:3000"
# Confía en el host (necesario detrás del proxy de Vercel)
AUTH_TRUST_HOST="true"

# ── Base de datos (Neon Postgres) ────────────────────────────────────────
# Crea una BD Neon gratis desde el Marketplace de Vercel o en neon.tech.
# Copia la "Connection string" (pooled) aquí:
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/coachcore?sslmode=require"

# ── Email (recuperación de contraseña) ───────────────────────────────────
# Opcional en dev: sin esto, el enlace de recuperación se imprime en consola.
# En producción, crea una API key en resend.com y verifica tu dominio.
RESEND_API_KEY=""
EMAIL_FROM="CoachCore <no-reply@tudominio.com>"

# ── Rate limiting distribuido (opcional) ─────────────────────────────────
# Sin esto se usa un limitador en memoria (suficiente para instancia única).
# Para multi-instancia: instala @upstash/ratelimit @upstash/redis y define:
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
